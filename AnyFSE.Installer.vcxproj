  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <WholeProgramOptimization>true</WholeProgramOptimization>
    <CharacterSet>Unicode</CharacterSet>
    <PreBuildEventUseInBuild>true</PreBuildEventUseInBuild>
    <OutputDirectory>build\$(Configuration)\</OutputDirectory>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <PropertyGroup>
    <OutDir>$(SolutionDir)build\$(Configuration)\</OutDir>
    <PackageDir>$(SolutionDir)build\Package\</PackageDir>
    <IntDir>$(SolutionDir)build\objs\$(ProjectName)\$(Configuration)\</IntDir>
    <TargetName>AnyFSE.Installer</TargetName>
    <OutExe>$(OutDir)$(TargetName).exe</OutExe>
    <CustomBuildBeforeTargets>ClCompile</CustomBuildBeforeTargets>
    <OldVersionRevision>$([MSBuild]::Add($(VersionRevision), -1))</OldVersionRevision>
  </PropertyGroup>


  <PropertyGroup Condition="'$(Configuration)|$(Platform)|$(Offline)'=='Release|x64|Offline'">
  <TargetName>AnyFSE.Installer.Offline.$(AssemblyVersion)-$(OldVersionRevision)</TargetName>
    <OutExe>$(OutDir)$(TargetName).exe</OutExe>
  </PropertyGroup>

  <ItemGroup>
    <ApplicationFiles Include="$(OutDir)*.cer" />
    <ApplicationFiles Include="$(OutDir)*.exe" Exclude="$(OutDir)AnyFSE.Installer*.exe" />
    <ApplicationFiles Include="$(OutDir)*.dll" />
    <ApplicationFiles Include="$(OutDir)Assets" />
    <ApplicationFiles Include="$(OutDir)AppxManifest.xml" />
    <ApplicationFiles Include="$(OutDir)priconfig.xml" />
    <ApplicationFiles Include="$(OutDir)resources.pri" />
    <ApplicationFiles Include="$(OutDir)resources.scale-200.pri" />
    <ApplicationFiles Include="$(OutDir)CustomCapability.SCCD" />
    <ApplicationFiles Include="$(OutDir)Localization" />
    <ApplicationFiles Include="$(OutDir)*.identity.appx" />
  </ItemGroup>
  <ItemGroup>
    <ApplicationDumpFiles Include="$(OutDir)AnyFSE*.pdb" Exclude="$(OutDir)AnyFSE*-*.pdb" />
  </ItemGroup>

  <PropertyGroup>
    <InstallFiles>@(ApplicationFiles->'&quot;%(RecursiveDir)%(Filename)%(Extension)&quot;', ' ')</InstallFiles>
    <PDBFiles>@(ApplicationDumpFiles->'&quot;%(RecursiveDir)%(Filename)%(Extension)&quot;', ' ')</PDBFiles>
  </PropertyGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>Disabled</Optimization>
      <PreprocessorDefinitions>
        _STATIC_CPPLIB;_DISABLE_DEPRECATE_STATIC_CPPLIB;WIN32;WIN64;_WIN64;_AMD64_;_DEBUG;WIN32;_WINDOWS;UNICODE;_UNICODE;
        VER_VERSION_STR="$(AssemblyVersion)";
        VER_PRODUCT_NAME="$(AssemblyProduct)";
        VER_COMPANY_NAME="$(AssemblyCompany)";
        VER_PUBLISHER_CN="$(PublisherCN)";
        %(PreprocessorDefinitions)
      </PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(ProjectDir)src</AdditionalIncludeDirectories>
      <DebugInformationFormat>ProgramDatabase</DebugInformationFormat>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <RuntimeLibrary>MultiThreadedDebug</RuntimeLibrary>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <DelayLoadDLLs>api-ms-win-gaming-experience-l1-1-0.dll</DelayLoadDLLs>
      <!-- <AdditionalDependencies>Shell32.lib;Ole32.lib;User32.lib;ComCtl32.lib;Advapi32.lib</AdditionalDependencies> -->
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>

      <PreprocessorDefinitions>
        _STATIC_CPPLIB;_DISABLE_DEPRECATE_STATIC_CPPLIB;WIN32;WIN64;_WIN64;_AMD64_;NDEBUG;WIN32;_WINDOWS;UNICODE;_UNICODE;
        VER_VERSION_STR="$(AssemblyVersion)";
        VER_PRODUCT_NAME="$(AssemblyProduct)";
        VER_COMPANY_NAME="$(AssemblyCompany)";
        VER_PUBLISHER_CN="$(PublisherCN)";
        %(PreprocessorDefinitions)
      </PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(ProjectDir)src</AdditionalIncludeDirectories>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <Optimization>MinSpace</Optimization>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <LinkIncremental>false</LinkIncremental>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <DelayLoadDLLs>api-ms-win-gaming-experience-l1-1-0.dll</DelayLoadDLLs>
      <!-- <AdditionalDependencies>delayimp.lib;Shell32.lib;Ole32.lib;User32.lib;ComCtl32.lib;Advapi32.lib</AdditionalDependencies> -->
    </Link>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Offline)'=='Offline'">
    <ClCompile>
      <PreprocessorDefinitions>
        OFFLINE_INSTALLER;
        APP_VERSION="$(AssemblyVersion)-$(OldVersionRevision)";
        %(PreprocessorDefinitions)
      </PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="src\AppInstaller\AppInstaller.cpp" />
    <ClCompile Include="src\AppInstaller\AppInstaller_Install.cpp" />
    <ClCompile Include="src\AppInstaller\AppInstaller_Page.cpp" />
    <ClCompile Include="src\AppInstaller\AppInstaller_Tools.cpp" />
    <ClCompile Include="src\AppInstaller\Admin.cpp" />
    <ClCompile Include="src\AppInstaller\Certificate.cpp" />
    <ClCompile Include="src\FluentDesign\Theme.cpp" />
    <ClCompile Include="src\FluentDesign\FluentControl.cpp" />
    <ClCompile Include="src\FluentDesign\Align.cpp" />
    <ClCompile Include="src\FluentDesign\Theme_Colors.cpp" />
    <ClCompile Include="src\FluentDesign\Button.cpp" />
    <ClCompile Include="src\FluentDesign\Static.cpp" />
    <ClCompile Include="src\FluentDesign\TextBox.cpp" />
    <ClCompile Include="src\FluentDesign\Popup.cpp" />
    <ClCompile Include="src\Tools\Packages.cpp" />
    <ClCompile Include="src\Tools\Event.cpp" />
    <ClCompile Include="src\Tools\Registry.cpp" />
    <ClCompile Include="src\Tools\Unicode.cpp" />
    <ClCompile Include="src\Tools\Window.cpp" />
    <ClCompile Include="src\Tools\Process.cpp" />
    <ClCompile Include="src\Tools\Icon.cpp" />
    <ClCompile Include="src\Tools\Paths.cpp" />
    <ClCompile Include="src\Tools\Localization.cpp" />
    <ClCompile Include="src\Logging\*.cpp" />
    <ClCompile Include="src\App\GamingExperience.cpp" />
    <ClCompile Include="src\Ally\Services.cpp" />
  </ItemGroup>
  <ItemGroup>
    <None Include="Assets\localization\*.json" />
  </ItemGroup>
  <ItemGroup>
    <ResourceCompile Include="src\AppInstaller\Installer.rc">
        <PreprocessorDefinitions Condition="'$(Offline)'=='Offline'">
            OFFLINE_INSTALLER;
            BUILD_ARCHIVE=\"$(OutDir.Replace('\', '\\'))$(AssemblyProduct).$(AssemblyVersion).zip\";
            %(PreprocessorDefinitions)
        </PreprocessorDefinitions>
      <AdditionalOptions>/v /I&quot;$(ProjectDir)src\Installer&quot;/I&quot;$(ProjectDir)src&quot;</AdditionalOptions>
    </ResourceCompile>
  </ItemGroup>

<ItemDefinitionGroup>
    <CustomBuildStep>
        <Message>Archive $(InstallFiles) and $(PDBFiles) to $(AssemblyProduct).$(AssemblyVersion).zip and $(AssemblyProduct).$(AssemblyVersion).pdb.zip </Message>
        <Command>if exist &quot;$(OutDir)Package&quot; xcopy &quot;$(OutDir)Package&quot; &quot;$(OutDir)&quot; /E /I /Y &amp;&amp; cd &quot;$(OutDir)&quot; &amp;&amp; tar -a -cf &quot;$(AssemblyProduct).$(AssemblyVersion).zip&quot; $(InstallFiles) &amp;&amp; tar -a -cf &quot;$(AssemblyProduct).$(AssemblyVersion).pdb.zip&quot; $(PDBFiles)</Command>
        <Outputs>$(AssemblyProduct).$(AssemblyVersion).zip; $(AssemblyProduct).$(AssemblyVersion).pdb.zip </Outputs>
    </CustomBuildStep>
</ItemDefinitionGroup>

    <!-- Target: Get certificate thumbprint by name -->
    <Target Name="GetCertificateThumbprint">
        <Message Text="Finding certificate for: $(AssemblyCompany)" Importance="high" />

        <Exec Command="powershell -NoProfile -Command &quot;try { $store = New-Object System.Security.Cryptography.X509Certificates.X509Store('My','CurrentUser'); $store.Open('ReadOnly'); $cert = $store.Certificates | Where-Object { $_.Subject -like '*$(AssemblyCompany)*' -and $_.HasPrivateKey -and -not $_.Extensions.CertificateAuthority } | Select-Object -First 1; if (-not $cert) { throw 'Certificate not found' }; $cert.Thumbprint } catch { Write-Error $_.Exception.Message; exit 1 } finally { if ($store) { $store.Close() } }&quot;" ContinueOnError="false" ConsoleToMSBuild="true">
            <Output TaskParameter="ConsoleOutput" PropertyName="CertificateThumbprint" />
        </Exec>

        <Message Text="Found certificate thumbprint: $(CertificateThumbprint)" Importance="high" />
    </Target>

    <!-- Target: Sign the EXE -->
    <Target Name="BuildSigned" DependsOnTargets="Build;GetCertificateThumbprint">
        <Message Text="Signing EXE with certificate: $(CertificateThumbprint)" Importance="high" />

        <!-- Run SignTool with the found certificate thumbprint -->
        <Exec Command="&quot;$(SignToolExe)&quot; sign /sha1 &quot;$(CertificateThumbprint)&quot; /fd SHA256 /a &quot;$(OutExe)&quot;" WorkingDirectory="$(MSBuildProjectDirectory)" />

        <Message Text="EXE signed successfully: $(OutExe)" Importance="high" />
    </Target>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
