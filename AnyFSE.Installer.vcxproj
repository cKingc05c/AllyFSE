    <SignToolExe>$(WindowsSdkToolsPath)\signtool.exe</SignToolExe>
  </PropertyGroup>
  <PropertyGroup Condition="'$(VCTargetsPath)'==''" >
    <VCTargetsPath>C:\Program Files\Microsoft Visual Studio\2022\Community\MSBuild\Microsoft\VC\v170\</VCTargetsPath>
  </PropertyGroup>
