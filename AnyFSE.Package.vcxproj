<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003" DefaultTargets="Package">

  <!-- Packaging properties -->
  <Import Project="AnyFSE.Version.props" />

    <PropertyGroup Label="Globals">
        <ProjectGuid>{4B2F1E9A-8C3D-4E76-9A1F-2D8C5A3B7E9F}</ProjectGuid>
    </PropertyGroup>

  <PropertyGroup>
    <OutDir>build\$(Configuration)\</OutDir>
    <Version>$(AssemblyVersion).$(VersionRevision)</Version>
    <TargetName>$(AssemblyProduct)</TargetName>
    <DefaultLanguage>En-US</DefaultLanguage>
    <AppxPackageSigningEnabled>True</AppxPackageSigningEnabled>
    <AppName>AllyFSE</AppName>
    <Publisher>$(AssemblyCompany)</Publisher>
    <Description>AllyFSE handheld FSE session manager</Description>
    <WindowsTargetPlatformVersion>10.0.26100.0</WindowsTargetPlatformVersion>
    <WindowsSdkDir Condition="'$(WindowsSdkDir)'==''">$(Registry:HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Kits\Installed Roots@KitsRoot10)</WindowsSdkDir>
    <WindowsSdkToolsPath>$(WindowsSdkDir)bin\$(WindowsTargetPlatformVersion)\x64</WindowsSdkToolsPath>
    <AppPackageContentsDir>$(MSBuildProjectDirectory)\build\objs\Package</AppPackageContentsDir>
    <AppPackagesDir>$(MSBuildProjectDirectory)\build\$(Configuration)</AppPackagesDir>
    <ExternalPayloadDir>$(AppPackagesDir)\Package</ExternalPayloadDir>
    <ExternalInstallDir>C:\Program Files\AnyFSE</ExternalInstallDir>
    <PackageFileName>$(AppPackagesDir)\$(TargetName)-$(AssemblyVersion).identity.appx</PackageFileName>
    <MakeAppxExe>$(WindowsSdkToolsPath)\MakeAppx.exe</MakeAppxExe>
    <MakePriExe>$(WindowsSdkToolsPath)\MakePri.exe</MakePriExe>
    <SignToolExe>$(WindowsSdkToolsPath)\signtool.exe</SignToolExe>
    <CertificateName>Artem Shpynov</CertificateName>
  </PropertyGroup>
  <!-- <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" /> -->

  <Target Name="Build">
  </Target>

  <Target Name="CreateAppPackageContents" DependsOnTargets="Build">
    <Message Text="Creating app package contents folder..." Importance="high" />

    <RemoveDir Directories="$(AppPackageContentsDir)" />
    <MakeDir Directories="$(AppPackageContentsDir)" />
    <MakeDir Directories="$(AppPackageContentsDir)\Assets" />

    <Copy
      SourceFiles="$(MSBuildProjectDirectory)\AppxManifest.xml"
      DestinationFiles="$(AppPackageContentsDir)\AppxManifest.xml" />

    <XmlPoke
      XmlInputPath="$(AppPackageContentsDir)\AppxManifest.xml"
      Query="//*[local-name()='Identity']/@Version"
      Value="$(Version)" />

    <XmlPoke
      XmlInputPath="$(AppPackageContentsDir)\AppxManifest.xml"
      Query="//*[local-name()='Properties']/*[local-name()='DisplayName']"
      Value="$(AppName)" />

    <XmlPoke
      XmlInputPath="$(AppPackageContentsDir)\AppxManifest.xml"
      Query="//*[local-name()='Properties']/*[local-name()='PublisherDisplayName']"
      Value="$(Publisher)" />

    <XmlPoke
      XmlInputPath="$(AppPackageContentsDir)\AppxManifest.xml"
      Query="//*[local-name()='Applications']/*[local-name()='Application']/@Executable"
      Value="$(TargetName).exe" />

    <XmlPoke
      XmlInputPath="$(AppPackageContentsDir)\AppxManifest.xml"
      Query="//*[local-name()='Applications']/*[local-name()='Application']/*[local-name()='VisualElements']/@DisplayName"
      Value="$(AppName)" />

    <XmlPoke
      XmlInputPath="$(AppPackageContentsDir)\AppxManifest.xml"
      Query="//*[local-name()='Applications']/*[local-name()='Application']/*[local-name()='VisualElements']/@DisplayName"
      Value="$(AppName)" />

    <XmlPoke
      XmlInputPath="$(AppPackageContentsDir)\AppxManifest.xml"
      Query="//*[local-name()='Applications']/*[local-name()='Application']/*[local-name()='VisualElements']/@Description"
      Value="$(Description)" />

    <XmlPoke
      XmlInputPath="$(AppPackageContentsDir)\AppxManifest.xml"
      Query="//*[local-name()='Applications']/*[local-name()='Application']/*[local-name()='Extensions']/*[local-name()='Extension']/*[local-name()='AppExtension']/@DisplayName"
      Value="$(AppName)" />

    <XmlPoke
      XmlInputPath="$(AppPackageContentsDir)\AppxManifest.xml"
      Query="//*[local-name()='Applications']/*[local-name()='Application']/*[local-name()='Extensions']/*[local-name()='Extension']/*[local-name()='AppExtension']/@Description"
      Value="$(Description)" />

    <ItemGroup>
      <AssetFiles Include="$(MSBuildProjectDirectory)\Assets\*" />
    </ItemGroup>
    <Copy
      SourceFiles="@(AssetFiles)"
      DestinationFolder="$(AppPackageContentsDir)\Assets" />

    <!-- Copy custom capability if exists -->
    <ItemGroup>
      <CustomCapabilityFile Include="$(MSBuildProjectDirectory)\CustomCapability.SCCD" />
    </ItemGroup>
    <Copy
      SourceFiles="@(CustomCapabilityFile)"
      DestinationFolder="$(AppPackageContentsDir)"
      SkipUnchangedFiles="false" />

    <Exec Command="&quot;$(MakePriExe)&quot; createconfig /cf priconfig.xml /dq en-US" WorkingDirectory="$(AppPackageContentsDir)" />
    <Exec Command="&quot;$(MakePriExe)&quot; new /pr &quot;$(AppPackageContentsDir)&quot; /cf &quot;$(AppPackageContentsDir)\priconfig.xml&quot;" WorkingDirectory="$(AppPackageContentsDir)" />

    <Message Text="App package contents created at: $(AppPackageContentsDir)" Importance="high" />
  </Target>

  <!-- Target: Create APPX package using MakeAppx -->
  <Target Name="CreateAppxPackage" DependsOnTargets="CreateAppPackageContents">
    <Message Text="Creating APPX package..." Importance="high" />

    <!-- Create output directory if it doesn't exist -->
    <MakeDir Directories="$(AppPackagesDir)" />

    <!-- Build a sparse identity package. Runtime binaries live in $(ExternalInstallDir). -->
    <Exec
      Command="&quot;$(MakeAppxExe)&quot; pack /overwrite /nv /d &quot;$(AppPackageContentsDir)&quot; /p &quot;$(PackageFileName)&quot;"
      WorkingDirectory="$(MSBuildProjectDirectory)" />

    <Message Text="APPX package created: $(PackageFileName)" Importance="high" />
  </Target>

  <!-- Target: Get certificate thumbprint by name -->
  <Target Name="GetCertificateThumbprint">
    <Message Text="Finding certificate for: $(CertificateName)" Importance="high" />

    <Exec Command="powershell -NoProfile -Command &quot;try { $store = New-Object System.Security.Cryptography.X509Certificates.X509Store('My','CurrentUser'); $store.Open('ReadOnly'); $cert = $store.Certificates | Where-Object { $_.Subject -like '*$(PublisherCN)*' -and $_.HasPrivateKey -and -not $_.Extensions.CertificateAuthority } | Select-Object -First 1; if (-not $cert) { throw 'Certificate not found' }; $cert.Thumbprint } catch { Write-Error $_.Exception.Message; exit 1 } finally { if ($store) { $store.Close() } }&quot;" ContinueOnError="false" ConsoleToMSBuild="true">
      <Output TaskParameter="ConsoleOutput" PropertyName="CertificateThumbprint" />
    </Exec>

    <Message Text="Found certificate thumbprint: $(CertificateThumbprint)" Importance="high" />
  </Target>

  <!-- Target: Sign the APPX package by certificate name -->
  <Target Name="SignAppPackage" DependsOnTargets="CreateAppxPackage;GetCertificateThumbprint">
    <Message Text="Signing APPX package with certificate: $(CertificateThumbprint)" Importance="high" />

    <!-- Run SignTool with the found certificate thumbprint -->
    <Exec Command="&quot;$(SignToolExe)&quot; sign /sha1 &quot;$(CertificateThumbprint)&quot; /fd SHA256 /a &quot;$(PackageFileName)&quot;" WorkingDirectory="$(MSBuildProjectDirectory)" />

    <Message Text="APPX package signed successfully: $(PackageFileName)" Importance="high" />
  </Target>

  <!-- Main Package target that orchestrates all steps -->
  <Target Name="Package" DependsOnTargets="SignAppPackage">
    <Message Text="Packaging complete! Package available at: $(PackageFileName)" Importance="high" />
    <ItemGroup>
      <PackageContent Include="$(AppPackageContentsDir)\**\*" />
      <CertificateFile Include="$(MSBuildProjectDirectory)\*.cer" />
    </ItemGroup>
    <PropertyGroup>
      <!-- First, calculate the incremented value -->
      <NewVersionRevision>$([MSBuild]::Add($(VersionRevision), 1))</NewVersionRevision>
    </PropertyGroup>
    <RemoveDir Directories="$(ExternalPayloadDir)" />
    <Copy
      SourceFiles="@(PackageContent)"
      DestinationFiles="@(PackageContent->'$(ExternalPayloadDir)\%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="false" />
    <Copy
      SourceFiles="@(CertificateFile)"
      DestinationFolder="$(OutDir)\" />

    <XmlPoke
      XmlInputPath="$(MSBuildProjectDirectory)/AnyFSE.Version.props"
      Query="/*/*/*[local-name()='VersionRevision']"
      Value="$(NewVersionRevision)"/>
  </Target>

</Project>
